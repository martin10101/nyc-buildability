{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/martin10101/nyc-buildability/services/api/app/rules/schemas/v1/evaluation_trace.schema.json",
  "title": "Rule Evaluation Trace (v1)",
  "description": "v1 full, exportable trace of one deterministic rule evaluation (M4-T001, PRD sections 11/12/19). Records the resolved inputs, the applicability decision with per-predicate reasoning, every computation step with resolved arguments and result, the citations WITH their source-snapshot provenance (a material value may never be exported without it), the coverage + data-completeness labels, and any propagated M2-T013 geometric uncertainty. coverage_status uses the canonical PRD-section-12 vocabulary; 'verified' appears only for a published rule evaluated with its G6 approval attached.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "rule_version",
    "rule_status",
    "family",
    "evaluated_inputs",
    "applicability_outcome",
    "applicability_trace",
    "computation_steps",
    "outputs",
    "coverage_status",
    "data_completeness",
    "citations",
    "uncertainty",
    "exceptions_applied",
    "notes",
    "input_validation",
    "rule_release",
    "effective_window",
    "determination"
  ],
  "properties": {
    "rule_id": {"type": "string"},
    "rule_version": {"type": "string"},
    "rule_status": {"type": "string", "enum": ["discovered", "extracted_draft", "needs_review", "published"]},
    "family": {"type": "string"},
    "evaluated_inputs": {"type": "object"},
    "applicability_outcome": {"type": "boolean"},
    "applicability_trace": {"type": "array", "items": {"type": "object"}},
    "computation_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "op", "resolved_args", "result", "note"],
        "properties": {
          "step_id": {"type": "string"},
          "op": {"type": "string"},
          "resolved_args": {"type": "array"},
          "result": {"type": "number"},
          "note": {"type": "string"}
        }
      }
    },
    "outputs": {"type": "object"},
    "coverage_status": {
      "type": "string",
      "enum": ["verified", "conditional", "professional_review_required", "data_conflict", "unsupported", "not_applicable"]
    },
    "data_completeness": {
      "type": "string",
      "enum": ["complete", "missing_noncritical", "missing_critical"]
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["snapshot_id", "section", "quote", "provenance"],
        "properties": {
          "snapshot_id": {"type": "string"},
          "section": {"type": "string"},
          "quote": {"type": "string"},
          "last_amended": {"type": ["string", "null"]},
          "provenance": {"type": "object"}
        }
      }
    },
    "uncertainty": {"type": "object"},
    "exceptions_applied": {"type": "array"},
    "notes": {"type": "array", "items": {"type": "string"}},
    "input_validation": {
      "type": "object",
      "additionalProperties": false,
      "description": "M4-T003: fail-closed input validation result. When valid is false the evaluation stops before computation and coverage is professional_review_required (no computed value).",
      "required": ["valid", "invalid_inputs"],
      "properties": {
        "valid": {"type": "boolean"},
        "invalid_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reason"],
            "properties": {
              "name": {"type": "string"},
              "reason": {"type": "string"},
              "value_seen": {}
            }
          }
        }
      }
    },
    "rule_release": {
      "type": "object",
      "additionalProperties": false,
      "description": "M4-T003: the rule's test/lifecycle release status carried per evaluation. verified_eligible is true only for a published rule evaluated with a matching G6 approval attached.",
      "required": ["lifecycle_status", "deterministic_tests", "independent_review", "qualified_human_approval", "verified_eligible"],
      "properties": {
        "lifecycle_status": {"type": "string", "enum": ["discovered", "extracted_draft", "needs_review", "published"]},
        "deterministic_tests": {"type": "string", "enum": ["declared", "none"]},
        "independent_review": {"type": "string", "enum": ["pending", "passed"]},
        "qualified_human_approval": {"type": "string", "enum": ["pending", "approved"]},
        "verified_eligible": {"type": "boolean"}
      }
    },
    "effective_window": {
      "type": "object",
      "additionalProperties": false,
      "description": "M4-T003: temporal effectiveness of this rule version relative to the evaluation as_of date. evaluated_as_of is null when the caller did not pass one (no temporal gating applied).",
      "required": ["effective_from", "effective_to", "evaluated_as_of", "in_effect"],
      "properties": {
        "effective_from": {"type": ["string", "null"]},
        "effective_to": {"type": ["string", "null"]},
        "evaluated_as_of": {"type": ["string", "null"]},
        "in_effect": {"type": "boolean"}
      }
    },
    "determination": {
      "description": "M4-T003: compliance pass/fail determination when the rule declares one and was applicable+computed; null otherwise. Never changes coverage.",
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["id", "compare", "left_value", "right_value", "outcome", "label"],
      "properties": {
        "id": {"type": "string"},
        "description": {"type": "string"},
        "compare": {"type": "string"},
        "left_value": {"type": ["number", "null"]},
        "right_value": {"type": ["number", "null"]},
        "outcome": {"type": "string", "enum": ["pass", "fail"]},
        "label": {"type": "string"}
      }
    }
  }
}
