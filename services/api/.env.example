# services/api — backend runtime environment variables (NAMES ONLY, NO VALUES).
#
# This file documents the variables the FastAPI service and Render workers read.
# Real values live ONLY in Render env vars / environment groups (declared
# `sync: false` in render.yaml; values entered in the Render dashboard, scoped
# per project environment). See docs/SECRETS_POLICY.md for the full inventory,
# storage locations, and rotation guidance.
#
# NEVER put a real value in this file. NEVER commit a real .env file
# (.gitignore blocks .env and .env.* — only .env.example is tracked).
# Local .env usage is reserved for future explicitly approved local
# development; default development is remote per the low-storage policy.
#
# CI-only secrets (SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD,
# SUPABASE_PROJECT_REF, RENDER_DEPLOY_HOOK_URL_*) live in GitHub environment
# secrets and intentionally do NOT appear here — they are never read by the
# application. (Vercel secrets removed per ADR-004: frontend served from Render.)

# Deployment environment name: staging | production (not a secret; env-scoped
# so a single Render Blueprint serves both environments — ADR-002).
ENVIRONMENT=

# Supabase project URL for this environment (env-scoped config).
SUPABASE_URL=

# Supabase service-role key — TRUSTED BACKEND ONLY. Bypasses RLS. Never in the
# frontend, never in CI, never in Git (PRD 14.3/17). Rotate immediately on
# suspected exposure.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for this environment's Supabase database
# (contains the DB password — secret).
SUPABASE_DB_URL=

# NYC API Developers Portal subscription key for Geoclient address/BBL/BIN
# resolution (secret; regenerate at api-portal.nyc.gov if exposed).
GEOCLIENT_SUBSCRIPTION_KEY=

# Anthropic API key for AI extraction workers (secret).
ANTHROPIC_API_KEY=

# Sentry DSN for error monitoring (low-sensitivity submit-only endpoint;
# treated as env-scoped config-secret, still never committed).
SENTRY_DSN=
