# apps/web — frontend environment variables (NAMES ONLY, NO VALUES).
#
# Real values live ONLY in Vercel env vars, scoped to the matching Vercel
# environment/branch (ADR-002). See docs/SECRETS_POLICY.md.
#
# SECURITY BOUNDARY: every NEXT_PUBLIC_* variable is compiled into the public
# browser bundle. ONLY publishable values may ever appear in this file or in
# any frontend configuration:
#   - the Supabase project URL
#   - the Supabase anon/publishable key (safe only because RLS enforces access)
#
# The Supabase SERVICE-ROLE key, database URLs, deploy hooks, provider tokens,
# or ANY other privileged credential must NEVER appear here, in any frontend
# env file, or anywhere under apps/web — with or without the NEXT_PUBLIC_
# prefix (PRD 14.3/17). If a frontend feature seems to need a privileged key,
# the call belongs in the backend API instead.
#
# NEVER put a real value in this file. NEVER commit a real .env file
# (.gitignore blocks .env and .env.* — only .env.example is tracked).

# Supabase project URL for this environment (publishable, env-scoped).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (publishable by design; protected by RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
